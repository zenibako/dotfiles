{
  "mcpServers": {
{{#if mcp_salesforce_enabled}}
    "Salesforce DX": {
      "command": "npx",
      "args": ["-y", "@salesforce/mcp", 
               "--orgs", "DEFAULT_TARGET_ORG", 
               "--toolsets", "all"]
    },
{{/if}}
{{#if n8n_mcp_token}}
    "n8n": {
      "type": "http",
      "url": "{{n8n_mcp_url}}",
      "headers": {
        "Authorization": "Bearer {{n8n_mcp_token}}"
      }
    },
{{/if}}
    "Chrome DevTools": {
      "command": "zsh",
      "args": [
        "-c",
        "source ~/.nvm/nvm.sh && nvm use --lts >&2 && npx chrome-devtools-mcp@latest"
      ]
    }{{#if mcp_odaseva_enabled}},
    "Odaseva": {
      "command": "oda-mcp",
      "args": ["-env", "/Users/{{ username }}/Projects/oda-mcp/.env"]
    }{{/if}}{{#if mcp_jujutsu_enabled}},
    "Jujutsu": {
      "command": "jj-mcp-server"
    }{{/if}}
  },
  "preferences": {
    "coworkScheduledTasksEnabled": true,
    "ccdScheduledTasksEnabled": true,
    "sidebarMode": "chat",
    "coworkWebSearchEnabled": true
  }
}