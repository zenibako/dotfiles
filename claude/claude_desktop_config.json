{
  "mcpServers": {
    "Jujutsu": {
      "command": "{{shell_bin_path}}/npx",
      "args": [
        "-y",
        "jj-mcp-server"
      ],
      "env": {
        "PATH": "{{shell_bin_path}}:/usr/bin:/bin:/usr/sbin:/sbin"
      }
    },
    "GitHub": {
      "command": "{{shell_bin_path}}/npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{{github_personal_access_token}}",
        "PATH": "{{shell_bin_path}}:/usr/bin:/bin:/usr/sbin:/sbin"
      }
    },
    "Backlog": {
      "command": "{{shell_bin_path}}/backlog",
      "args": [
        "mcp",
        "start"
      ]
    },
    "Playwright": {
      "command": "{{shell_bin_path}}/npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ],
      "env": {
        "PATH": "{{shell_bin_path}}:/usr/bin:/bin:/usr/sbin:/sbin"
      }
    },
    "Chrome DevTools": {
      "command": "{{shell_bin_path}}/npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--launch"
      ],
      "env": {
        "PATH": "{{shell_bin_path}}:/usr/bin:/bin:/usr/sbin:/sbin"
      }
    }
  },
  "preferences": {
    "chillingSlothLocation": {
      "customPath": "/Users/{{username}}/Projects/workspaces"
    },
    "coworkScheduledTasksEnabled": true,
    "ccdScheduledTasksEnabled": true,
    "sidebarMode": "epitaxy",
    "coworkWebSearchEnabled": true,
    "epitaxyPrefs": {
      "starred-local-code-sessions": [],
      "starred-cowork-spaces": [],
      "starred-session-groups": [],
      "dframe-local-slice": {
        "pinnedOrder": [],
        "customGroupAssignments": {},
        "customGroupOrder": {}
      },
      "cc-landing-worktree-enabled": false,
      "epitaxy-perm-mode-acks.c5055d6d-b6e9-46de-a26f-0dad4c6255fc": [
        "/Users/chanderson/projects/home-assistant:auto",
        "/Users/chanderson/projects/cuejitsu:auto"
      ],
      "epitaxy-folder-permission-mode.c5055d6d-b6e9-46de-a26f-0dad4c6255fc": {
        "/Users/chanderson/projects/home-assistant": "auto",
        "/Users/chanderson/projects/cuejitsu": "auto"
      }
    },
    "remoteToolsDeviceName": "{{claude_remote_tools_device_name}}",
    "bypassPermissionsGateByAccount": {
      "{{claude_bypass_permissions_account_id}}": true
    },
    "ccRemoteControlDefaultEnabled": {{claude_agent_push_notif_enabled}},
    "bypassPermissionsOptInByAccount": {
      "{{claude_bypass_permissions_account_id}}": true
    }
  }
}