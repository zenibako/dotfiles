{
  "mcpServers": {
    "Jujutsu": {
      "command": "{{shell_bin_path}}/npx",
      "args": ["-y", "jj-mcp-server"],
      "env": {
        "PATH": "{{shell_bin_path}}:/usr/bin:/bin:/usr/sbin:/sbin"
      }
    },
    "GitHub": {
      "command": "{{shell_bin_path}}/npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{{github_personal_access_token}}",
        "PATH": "{{shell_bin_path}}:/usr/bin:/bin:/usr/sbin:/sbin"
      }
    },
    "Backlog": {
      "command": "{{shell_bin_path}}/backlog",
      "args": ["mcp", "start"]
    },
    "Playwright": {
      "command": "{{shell_bin_path}}/npx",
      "args": ["-y", "@playwright/mcp@latest"],
      "env": {
        "PATH": "{{shell_bin_path}}:/usr/bin:/bin:/usr/sbin:/sbin"
      }
    }
    {{#if opencode_profile_work}},
    "GitLab": {
      "command": "{{shell_bin_path}}/npx",
      "args": ["-y", "@modelcontextprotocol/server-gitlab"],
      "env": {
        "GITLAB_PERSONAL_ACCESS_TOKEN": "{{gitlab_personal_access_token}}",
        "GITLAB_API_URL": "{{gitlab_api_url}}",
        "PATH": "{{shell_bin_path}}:/usr/bin:/bin:/usr/sbin:/sbin"
      }
    }
    {{#if mcp_atlassian_enabled}},
    "Atlassian": {
      "command": "{{shell_bin_path}}/npx",
      "args": ["-y", "mcp-remote", "https://mcp.atlassian.com/v1/sse"],
      "env": {
        "PATH": "{{shell_bin_path}}:/usr/bin:/bin:/usr/sbin:/sbin"
      }
    }
    {{/if}}
    {{#if mcp_sonarqube_enabled}}{{#if sonarqube_url}}{{#if sonarqube_token}},
    "SonarQube": {
      "command": "{{shell_bin_path}}/docker",
      "args": [
        "run", "--init", "--pull=always", "-i", "--rm",
        "-e", "SONARQUBE_URL",
        "-e", "SONARQUBE_TOKEN",
        "mcp/sonarqube"
      ],
      "env": {
        "DOCKER_CONTEXT": "desktop-linux",
        "PATH": "{{shell_bin_path}}:/usr/bin:/bin:/usr/sbin:/sbin",
        "SONARQUBE_URL": "{{sonarqube_url}}",
        "SONARQUBE_TOKEN": "{{sonarqube_token}}"
      }
    }
    {{/if}}{{/if}}{{/if}}
    {{/if}},
    "Chrome DevTools": {
      "command": "{{shell_bin_path}}/npx",
      "args": ["-y", "chrome-devtools-mcp@latest", "--launch"],
      "env": {
        "PATH": "{{shell_bin_path}}:/usr/bin:/bin:/usr/sbin:/sbin"
      }
    }
  },
  "preferences": {
    "chillingSlothLocation": {
      "customPath": "/Users/{{username}}/Projects/workspaces"
    },
    "coworkScheduledTasksEnabled": false,
    "ccdScheduledTasksEnabled": true,
    "sidebarMode": "chat",
    "coworkWebSearchEnabled": true,
    "epitaxyPrefs": {
      "starred-local-code-sessions": [],
      "starred-cowork-spaces": [],
      "starred-session-groups": [],
      "dframe-local-slice": {
        "pinnedOrder": [],
        "customGroupAssignments": {},
        "customGroupOrder": {}
      }
    }
  }
}