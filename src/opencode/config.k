import json
import regex
import _shared.mcp as mcp_shared

# ── OpenCode (opencode.jsonc) ────────────────────────────────────────
# Generated by KCL using shared MCP server definitions.
# Profile-specific servers are included but disabled by default.
# Secrets (tokens) are injected by patch_opencode_secrets.py during deploy.

# LSP definitions
_lsp = {
    "basedpyright" = {
        "command" = ["basedpyright-langserver", "--stdio"]
        "extensions" = [".py"]
    }
    "gopls" = {
        "command" = ["gopls"]
        "extensions" = [".go"]
    }
    "html" = {
        "command" = ["vscode-html-language-server", "--stdio"]
        "extensions" = [".html", ".templ"]
    }
    "jsonls" = {
        "command" = ["vscode-json-language-server", "--stdio"]
        "extensions" = [".json", ".jsonc"]
    }
    "lua_ls" = {
        "command" = ["lua-language-server"]
        "extensions" = [".lua"]
    }
    "yamlls" = {
        "command" = ["yaml-language-server", "--stdio"]
        "extensions" = [".yml", ".yaml"]
    }
    "cue" = {
        "command" = ["cue", "lsp"]
        "extensions" = [".cue"]
    }
    "typescript-language-server" = {
        "command" = ["typescript-language-server", "--stdio"]
        "extensions" = [".ts", ".tsx", ".js", ".jsx"]
    }
    "kcl-lsp" = {
        "command" = ["kcl-language-server"]
        "extensions" = [".k", ".kcl"]
    }
    # Work profile LSPs (disabled by default)
    "apex-language-server" = {
        "command" = [
            "java",
            "-Ddebug.internal.errors=true",
            "-Ddebug.semantic.errors=false",
            "-Ddebug.completion.statistics=false",
            "-Dlwc.typegeneration.disabled=true",
            "apex.jorje.lsp.ApexLanguageServerLauncher"
        ]
        "extensions" = [".apex", ".cls", ".trigger"]
        "disabled" = True
        "initialization" = {
            "enableSemanticErrors" = True
            "enableCompletionStatistics" = False
        }
    }
    "lwc-language-server" = {
        "command" = ["~/.config/opencode/script/lwc-lsp-wrapper.sh"]
        "extensions" = [".js", ".html"]
        "disabled" = True
    }
    "visualforce-language-server" = {
        "command" = ["$HOME/.local/share/nvim/mason/bin/visualforce-language-server", "--stdio"]
        "extensions" = [".page", ".component"]
        "disabled" = True
    }
    "gitlab-ci-ls" = {
        "command" = ["gitlab-ci-ls"]
        "extensions" = [".gitlab-ci.yml", ".gitlab-ci.yaml"]
        "disabled" = True
    }
    "terraform-ls" = {
        "command" = ["terraform-ls", "serve"]
        "extensions" = [".tf", ".tfvars", ".hcl"]
        "disabled" = True
    }
    # Personal profile LSPs (disabled by default)
    "jinja-lsp" = {
        "command" = ["jinja-lsp"]
        "extensions" = [".jinja", ".jinja2"]
        "disabled" = True
    }
    "sourcekit-lsp" = {
        "command" = ["sourcekit-lsp"]
        "extensions" = [".swift"]
        "disabled" = True
    }
}

# Provider config
_provider = {
    "ollama" = {
        "npm" = "@ai-sdk/openai-compatible"
        "name" = "Ollama (local)"
        "options" = {
            "baseURL" = "http://localhost:11434/v1"
        }
        "models" = {
            "gemma4:12b-mlx" = {
                "name" = "Gemma 4 12B (MLX)"
            }
            "gemma4:12b-it-qat" = {
                "name" = "Gemma 4 12B (IT-QAT)"
            }
        }
    }
    "lmstudio" = {
        "npm" = "@ai-sdk/openai-compatible"
        "name" = "LM Studio (local)"
        "options" = {
            "baseURL" = "http://127.0.0.1:1234/v1"
        }
        "models" = {
            "qwen3.5-9b" = {
                "name" = "Qwen 3.5 9B"
            }
        }
    }
}

# Agent system prompts live in external Markdown files under
# src/opencode/prompt/agents/*.md, deployed to ~/.config/opencode/prompt/agents/
# via the symlinked prompt/ dir. OpenCode resolves the {file:...} reference at
# runtime (~/ absolute path), keeping this config lean and the prompts editable
# as plain Markdown rather than embedded KCL strings.
_agent_prompt = lambda name: str -> str {
    "{file:~/.config/opencode/prompt/agents/" + name + ".md}"
}

# Per-agent MCP scoping. OpenCode silently ignores a per-agent `mcp` field, so
# MCP access is controlled with `permission` wildcards (which DO apply per agent,
# including primary agents). Built-in tools keep their default (allow); only
# MCP-server tools are denied. NOTE (verified against opencode v1.18 source):
# a string-form deny rule (pattern "*") REMOVES the tool schema from the model
# request (session/llm/request.ts resolveTools + Permission.disabled) and drops
# the server's MCP instructions from the system prompt (session/system.ts) — so
# this is a real context lever, not just an execution gate. Host-level exclusion
# (_MCP_HOST_EXCLUDED in _shared/mcp.k) additionally avoids spawning the server.

# MCP tool keys are `sanitize(server) + "_" + sanitize(tool)` with any char
# outside [a-zA-Z0-9_-] replaced by "_" (opencode mcp/catalog.ts). Patterns must
# be built from the sanitized name or multi-word servers ("Chrome DevTools",
# "Home Assistant") silently never match — neither for context stripping nor
# for execution gating.
_sanitize_mcp = lambda name: str -> str {
    regex.replace(name, "[^a-zA-Z0-9_-]", "_")
}

_deny_all_mcp = {_sanitize_mcp(name) + "*": "deny" for name in mcp_shared.mcp_server_names}

# Deny all MCP tools except the named servers (built-in tools untouched). The
# deny set excludes `keep` so there is no conflicting key with the allow set
# (KCL's `|` errors on conflicting values rather than overriding).
_mcp_only = lambda keep: [str] -> {str:str} {
    {_sanitize_mcp(name) + "*": "deny" for name in mcp_shared.mcp_server_names if name not in keep} \
    | {_sanitize_mcp(k) + "*": "allow" for k in keep}
}

# Agent config
_agent = {
    "build" = {
        "model" = "{{opencode_build_agent_model}}"
        "prompt" = _agent_prompt("build")
    }
    "plan" = {
        "model" = "{{opencode_plan_agent_model}}"
        "prompt" = _agent_prompt("plan")
    }
    "local" = {
        "description" = "Local orchestrator; delegates to subagents. No MCP tools."
        "model" = "{{opencode_local_agent_model}}"
        "prompt" = _agent_prompt("local")
        # Router only: no MCP servers, no file edits (edit deny also removes the
        # edit/write/apply_patch schemas), no skills — keeps the small local
        # model's context as lean as possible.
        "permission" = _deny_all_mcp | {"edit" = "deny", "skill" = "deny"}
    }
    "tester" = {
        "description" = "Writes and runs tests via the project's own test runner and reports results"
        "mode" = "subagent"
        "model" = "{{opencode_test_agent_model}}"
        "prompt" = _agent_prompt("tester")
        # Runs test commands via bash; needs no MCP servers. Skills: radar for
        # orientation, but not the jj conflict workflow (tester never commits).
        "permission" = _deny_all_mcp | {
            "skill" = {"jj-sequential-conflict-resolution" = "deny"}
        }
    }
    "reviewer" = {
        "description" = "Reviews the session diff using jj/git; only needs Jujutsu + GitHub MCPs"
        "mode" = "subagent"
        # Same model as the plan agent — strong reasoning, lower cost than build.
        "model" = "{{opencode_plan_agent_model}}"
        "prompt" = _agent_prompt("reviewer")
        # Read-only (never edits files; keeps bash/read/grep for diffs) and scoped
        # to the Jujutsu + GitHub MCP servers; all other MCP tools denied.
        "permission" = {"edit" = "deny"} | _mcp_only(["Jujutsu", "GitHub"])
    }
    "local-pm" = {
        "description" = "Local Project Management subagent that uses Backlog.md to write and read tasks"
        "mode" = "subagent"
        "model" = "{{opencode_local_agent_model}}"
        "prompt" = _agent_prompt("local-pm")
        # Backlog MCP only (its core function; Backlog commits its own task
        # files, so Jujutsu isn't needed). No file edits, no skills — neither
        # skill is relevant to PM work.
        "permission" = _mcp_only(["Backlog"]) | {"edit" = "deny", "skill" = "deny"}
    }
    "local-dev" = {
        "description" = "Local Development subagent that writes code and commits work (VCS via jj/git CLI)"
        "mode" = "subagent"
        "model" = "{{opencode_local_agent_model}}"
        "prompt" = _agent_prompt("local-dev")
        # CLI-first for the small local model: no MCP servers at all. The
        # Jujutsu MCP alone is ~60 tool schemas per request — `jj` via bash
        # costs none. Skills stay at default (radar + jj conflict workflow).
        "permission" = _deny_all_mcp
    }
}

opencode = {
    "$schema" = "https://opencode.ai/config.json"
    "plugin" = []
    "small_model" = "lmstudio/qwen3.5-9b"
    "compaction" = {
        "auto" = True
        "prune" = True
        "reserved" = 2048
    }
    "permission" = {
        "external_directory" = {
            "/tmp/**" = "allow"
            "/private/tmp/**" = "allow"
        }
    }
    "mcp" = {}  # Replaced by `build()` with the KCL-generated mcp dict
    "lsp" = _lsp
    "provider" = _provider
    "agent" = _agent
}

# JSONC output helper — writes a dict as JSON with a header comment
_jsonc_header = """/**
 * # PREREQUISITES:
 * - OpenCode CLI: https://opencode.ai/docs/cli/installation
 * - `npm install`
 * - Review this file and follow any inline directions in the comments.
 *
 * # INSTRUCTIONS:
 * 1. Copy this file to `~/.config/opencode/`. Remove any other `opencode.json` or `opencode.jsonc` files in that directory.
 * 2. Authenticate with Github Copilot: https://opencode.ai/docs/cli/authentication
 * 3. Run OpenCode and select the model you want to use from Github Copilot: `opencode` `/models`
 * 4. Go forth and prompt!
 */
"""

# Build the JSONC output for the given effective MCP inclusion list.
# The mcp dict is generated at KCL time so excluded servers are literally
# omitted and the rendered JSON is always valid (no Handlebars leading-comma
# tricks). URLs/tokens remain Handlebars placeholders resolved by dotter, and
# post-deploy secret injection adds bearer tokens to the live file.
build = lambda included {
    _opencode_with_mcp = {k: v for k, v in opencode if k != "mcp"} | {"mcp": mcp_shared.opencode_mcp_for(included)}
    _jsonc_header + json.encode(_opencode_with_mcp, indent=2)
}
