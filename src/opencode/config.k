# Provider config
_provider = {
    "ollama" = {
        "npm" = "@ai-sdk/openai-compatible"
        "name" = "Ollama (local)"
        "options" = {
            "baseURL" = "http://localhost:11434/v1"
        }
        "models" = {
            "gemma4:12b-mlx" = {
                "name" = "Gemma 4 12B (MLX)"
            }
            "gemma4:12b-it-qat" = {
                "name" = "Gemma 4 12B (IT-QAT)"
            }
        }
    }
    "lmstudio" = {
        "npm" = "@ai-sdk/openai-compatible"
        "name" = "LM Studio (local)"
        "options" = {
            "baseURL" = "http://127.0.0.1:1234/v1"
        }
        # `limit` is mandatory for local models: models.dev has no entry for an
        # LM Studio model id, so opencode falls back to max_tokens=32000. The
        # MLX engine reserves that entire output budget against the loaded
        # context up front, so a ~6k-token prompt + 32k reserved needs ~38k and
        # LM Studio rejects the request with "number of tokens to keep from the
        # initial prompt is greater than the context length" — even though the
        # prompt itself is tiny. `context` must not exceed the context length
        # the model is actually loaded with in LM Studio (per-model load
        # setting); `output` is the real ceiling on a reply.
        # SUBSTITUTION HAZARD — why every entry below shares one context limit.
        # LM Studio serves whatever model is *resident* regardless of the `model`
        # field in the request. With only the 27B loaded, a request saying
        # "model": "qwen3.5-9b" is answered by the 27B and the log shows
        # `[qwen3.6-27b] Running chat completion` — no error, no warning.
        # opencode still budgets that session against the 9B's declared limit.
        # That is not academic: it crashed a session on 2026-07-22. `explore`
        # is pinned to the 9B, so opencode let its context grow toward 32,768,
        # but the 27B was answering and died at its ~24,600-token wall with a
        # Metal OOM, taking the whole backend down mid-task.
        # Co-residency would fix the substitution but does not fit: the 27B
        # (11 GB) plus the 8-bit 9B (9.7 GB) is ~20 GiB of weights against a
        # 20 GiB wired limit, before any KV cache.
        # So every model here carries the SMALLEST safe limit across the models
        # that might actually answer. Raising one in isolation reintroduces the
        # crash. If you ever load only the 9B and want its full window back,
        # raise them together — or accept that the ceiling is set by whichever
        # model is loaded, not by which one you asked for.
        "models" = {
            "qwen3.5-9b" = {
                "name" = "Qwen 3.5 9B"
                "limit" = {"context" = 20480, "output" = 8192}
            }
            # 27B is memory-bound on a 24 GiB machine, and LM Studio loads it
            # through the mlx-vlm path (no KV-cache quantization available).
            # Its `[context_fit]` log charges ~170 KiB/token — full_kv 64 KiB +
            # prompt_inputs 10 KiB + attention 96 KiB — so with
            # iogpu.wired_limit_mb=20480 (working_set 20 GiB, safe_ceiling 17
            # GiB, baseline 14.95 GiB) it fits only 11,776 tokens. Configuring
            # LM Studio above the fitted value is what produced "the number of
            # tokens to keep from the initial prompt is greater than the context
            # length": the cache layer keeps using `configured` while the engine
            # allocated `fitted`. Keep this at or below the LM Studio context
            # slider, and keep that at or below `fitted=`.
            # Now the 3-bit MLX quant (leonsarmiento/Qwen3.6-27B-3bit-mlx),
            # loaded under the SAME LM Studio identifier as the 4-bit it
            # replaced — hence one entry, not two. Confirm which is actually
            # resident with:
            #   curl -s localhost:1234/api/v0/models | jq '.data[].publisher'
            #
            # THIS MODEL HAS NO AUTO-FIT. It loads through mlx_engine's
            # `batched_model_kit`, which — unlike the plain MLX path the 4-bit
            # used — emits no `[context_fit]` line and never clamps the context
            # to what actually fits. Nothing sizes the KV cache against the GPU
            # budget, so an over-long prompt does not fail with "the number of
            # tokens to keep..."; it hard-crashes the Python backend:
            #   [METAL] Command buffer execution failed: Insufficient Memory
            #   (kIOGPUCommandBufferCallbackErrorOutOfMemory)
            # There is therefore no `fitted=` to read, and the only source of
            # truth is measurement. Probed 2026-07-22 (single-shot, temp 0):
            #   9,016 / 22,516 prompt tokens -> OK
            #   ~31,500 -> crashed at 78% of prompt processing, i.e. the wall is
            #   at roughly 24,600 tokens of KV cache
            #
            # The earlier arithmetic (~32,900 fitted, from 12.1 GB of
            # safetensors and the 4-bit's 182.5 KiB/token) was wrong twice over:
            # file size is not resident size, and the per-token cost does not
            # carry across quants or across engine paths. LM Studio also reports
            # this model's quantization as "4bit" despite the name, and the repo
            # ships a 128 kB config.json — mixed per-layer quant, not uniform
            # 3-bit.
            #
            # 20480 sits ~4,000 tokens below the measured wall on purpose: the
            # failure mode is a process death costing a manual reload, not a
            # recoverable error, and KV cost varies with content while other
            # apps compete for the same GPU budget.
            #
            # ALSO SET THE LM STUDIO CONTEXT SLIDER TO MATCH. It is loaded at
            # 32,768 — above the hardware wall — so any conversation that grows
            # past ~24,600 crashes the backend. The "Stop at limit" overflow
            # policy only triggers at the *configured* length, so it cannot
            # protect anything while that length is above what the GPU can hold.
            "qwen3.6-27b" = {
                "name" = "Qwen 3.6 27B"
                "limit" = {"context" = 20480, "output" = 8192}
            }
        }
    }
}

# Agent system prompts live in external Markdown files under
# src/opencode/prompt/agents/*.md, deployed to ~/.config/opencode/prompt/agents/
# via the symlinked prompt/ dir. OpenCode resolves the {file:...} reference at
# runtime (~/ absolute path), keeping this config lean and the prompts editable
# as plain Markdown rather than embedded KCL strings.
_agent_prompt = lambda name: str -> str {
    "{file:~/.config/opencode/prompt/agents/" + name + ".md}"
}

# Per-agent MCP scoping. OpenCode silently ignores a per-agent `mcp` field, so
# MCP access is controlled with `permission` wildcards (which DO apply per agent,
# including primary agents). Built-in tools keep their default (allow); only
# MCP-server tools are denied. NOTE (verified against opencode v1.18 source):
# a string-form deny rule (pattern "*") REMOVES the tool schema from the model
# request (session/llm/request.ts resolveTools + Permission.disabled) and drops
# the server's MCP instructions from the system prompt (session/system.ts) — so
# this is a real context lever, not just an execution gate. Host-level exclusion
# (_MCP_HOST_EXCLUDED in _shared/mcp.k) additionally avoids spawning the server.

# MCP tool keys are `sanitize(server) + "_" + sanitize(tool)` with any char
# outside [a-zA-Z0-9_-] replaced by "_" (opencode mcp/catalog.ts). Patterns must
# be built from the sanitized name or multi-word servers ("Chrome DevTools",
# "Home Assistant") silently never match — neither for context stripping nor
# for execution gating.
_sanitize_mcp = lambda name: str -> str {
    regex.replace(name, "[^a-zA-Z0-9_-]", "_")
}

_deny_all_mcp = {_sanitize_mcp(name) + "*": "deny" for name in mcp_shared.mcp_server_names}

# Deny all MCP tools except the named servers (built-in tools untouched). The
# deny set excludes `keep` so there is no conflicting key with the allow set
# (KCL's `|` errors on conflicting values rather than overriding).
_mcp_only = lambda keep: [str] -> {str:str} {
    {_sanitize_mcp(name) + "*": "deny" for name in mcp_shared.mcp_server_names if name not in keep} \
    | {_sanitize_mcp(k) + "*": "allow" for k in keep}
}

# local-dev's curated Jujutsu MCP slice: read-only inspection only. These are
# the high-frequency orient/verify calls where structured tool output beats
# parsing CLI text and there is no shell-quoting risk. Every *mutation* stays on
# the `jj` CLI via bash: `commit` needs the AI_CO_AUTHOR trailer (injected only
# into the bash tool env by the ai-coauthor plugin's shell.env hook — an MCP
# call runs jj with no shell and would silently drop it), and the
# jj-sequential-conflict-resolution skill drives edit/restore/new in CLI terms.
_local_dev_jj_read_tools = ["status", "diff", "log", "show"]

# explore's read-only Backlog slice. The `local` orchestrator cannot afford the
# Backlog server (see the `local` block), so task triage lands here — explore is
# already the agent `local` delegates every "go find out X" question to, and on
# the 9B it has the headroom. Read-only by construction: this is the complete
# list of non-mutating Backlog tools, so no `task_create`/`task_edit`/
# `task_complete`/`*_archive`/`*_upsert`, and nothing that touches milestones
# (creating and reorganizing work stays a human decision). Cheap, too — the six
# together are ~911 est. tokens, vs ~4,440 for the whole server, because the
# write tools carry the big schemas (`task_edit` alone is ~1,351).
_explore_backlog_read_tools = [
    "task_list"
    "task_search"
    "task_view"
    "document_list"
    "document_search"
    "document_view"
]

# local-pm's Backlog write slice. The read/write split across two agents is
# forced by `local`'s 27B budget (see the `local` block): triage is
# high-frequency and rides along with the discovery `explore` already does,
# while writes are rare, deliberate, and expensive to get wrong — so they get
# their own agent that is only spawned when the user actually asks for one.
# `task_edit` alone is ~1,351 est. tokens, 30% of the whole Backlog server;
# isolating it here keeps it out of every other agent's request.
# `task_search`/`task_view` come along because the first step of writing a task
# is checking it does not already exist.
# Deliberately absent: `document_*` and `milestone_*` (restructuring a project
# is not a subagent's call) and `*_archive` (destructive; ask the user).
_local_pm_backlog_write_tools = [
    "task_search"
    "task_view"
    "task_create"
    "task_edit"
    "task_complete"
]

# MCP *resource* plumbing. opencode ships these three regardless of whether any
# MCP server is reachable, so they are dead weight for any agent that denies
# servers wholesale. Verified against captured requests, not guessed.
# CAVEAT (measured 2026-07-22, opencode 1.18.4): the deny strips them for the
# primary agent `local`, but not for the subagents `local-dev` or `explore` —
# there they stay in the request regardless. The split is primary vs subagent,
# not MCP-related: `explore` allows no MCP tools at all and still keeps them,
# and a string deny of `webfetch` in the same ruleset *does* strip for both
# subagents. Not the skill ruleset either (isolated by re-measuring without it).
# Root cause unconfirmed. Residual cost ~1,300 bytes (~330 tokens) per subagent
# request. The denies stay: correct intent, and they do work for `local`.
_mcp_resource_tools = [
    "list_mcp_resources"
    "read_mcp_resource"
    "list_mcp_resource_templates"
]

# Skills local-dev keeps. Everything else is filtered out of <available_skills>
# by a `{"*": "deny", <name>: "allow"}` ruleset — the same deny-then-allow,
# order-sensitive findLast resolution the MCP patterns use (verified: a captured
# local-dev request went from 52 skills / 30,014 chars to exactly the named set).
# The wildcard matters more than the savings: the global catalogs under
# ~/.agents/skills and ~/.opencode/skills change whenever a skill is installed,
# and enumerating the denied names here would rot immediately.
#
# Kept: the Lattice *atoms* that govern how code gets written, plus the two
# workflow skills local-dev's own prompt references. Deliberately dropped: every
# `*-refiner` and `lattice-init` (interactive setup conversations), the
# requirement/design/review molecules (orchestrator and PM work, not
# implementation), and the Cloudflare/wiki/validate catalogs (project-specific;
# a subagent handed a precise brief does not browse for them).
_local_dev_skills = [
    "clean-code"
    "secure-coding"
    "architecture"
    "test-quality"
    "domain-driven-design"
    "jj-sequential-conflict-resolution"
    "radar-navigation"
]

# Built-in tools the `local` orchestrator is denied, on top of edit/bash/skill.
# Names are the literal tool ids opencode sends (verified against a captured
# /v1/chat/completions request, not guessed — a misspelled id silently no-ops).
#   read/grep/glob/webfetch — its prompt routes all discovery to `explore`;
#     leaving them available invites the small model to accumulate context in
#     the router instead of delegating (same failure mode that got `bash`
#     denied).
#   *_mcp_resource* — MCP resource plumbing, dead weight once _deny_all_mcp has
#     denied every server; opencode ships them regardless.
# Leaves exactly `task` (delegation) and `todowrite` (pipeline tracking).
#
# This roster is set by the 27B's context window, not by taste — see the
# `local` block below. Adding anything here has to be paid for out of ~4,000
# tokens of working room.
_local_router_denied_tools = [
    "read"
    "grep"
    "glob"
    "webfetch"
] + _mcp_resource_tools

# Agent config
_agent = {
    "build" = {
        "model" = "{{opencode_build_agent_model}}"
        "prompt" = _agent_prompt("build")
    }
    "plan" = {
        "model" = "{{opencode_plan_agent_model}}"
        "prompt" = _agent_prompt("plan")
    }
    "local" = {
        "description" = "Local orchestrator; delegates to subagents. No MCP tools."
        "model" = "{{opencode_local_agent_model}}"
        "prompt" = _agent_prompt("local")
        # Router only: no MCP servers, no file edits (edit deny also removes the
        # edit/write/apply_patch schemas), no skills — keeps the small local
        # model's context as lean as possible. bash is denied too: with it
        # available, the small model bypasses the edit denial via sed/cat
        # instead of delegating to local-dev (observed with qwen3.5-9b).
        # Reading/searching/fetching go too — see _local_router_denied_tools.
        #
        # WHY THE BACKLOG MCP IS NOT HERE (measured 2026-07-22, per-tool bytes
        # via scripts/measure_opencode_context.py; full table in Backlog doc-1).
        # Folding the old `local-pm` subagent in here and allowing the Backlog
        # server outright works fine on the 9B, but it takes `local` off the
        # 27B, which is the one agent the 27B can still run on this machine
        # (11,776 fitted tokens — src/launchd/iogpu_wired_limit.k). The budget:
        #   usable = 11,776 - 2,048 (compaction.reserved) = 9,728
        #   floor  = ~3,920 system prompt + 1,746 (task + todowrite) = ~5,666
        # That floor is not negotiable — the system prompt is opencode's own and
        # a router cannot give up `task`. It leaves ~4,060 for actual work, and
        # every Backlog schema comes out of that: the smallest useful read-only
        # slice (task_list/search/view, ~669) drops it to ~3,393 — the same
        # budget that had `explore` looping on compaction. The full server is
        # ~4,440 and overruns the window outright. So Backlog lives on `explore`
        # (pinned to the 9B) instead, and the router reaches it via `task`.
        "permission" = _deny_all_mcp | {"edit" = "deny", "bash" = "deny", "skill" = "deny"} \
            | {t: "deny" for t in _local_router_denied_tools}
    }
    "tester" = {
        "description" = "Writes and runs tests via the project's own test runner and reports results"
        "mode" = "subagent"
        "model" = "{{opencode_test_agent_model}}"
        "prompt" = _agent_prompt("tester")
        # Runs test commands via bash; needs no MCP servers. Skills: radar for
        # orientation, but not the jj conflict workflow (tester never commits).
        "permission" = _deny_all_mcp | {
            "skill" = {"jj-sequential-conflict-resolution" = "deny"}
        }
    }
    "reviewer" = {
        "description" = "Reviews the session diff using jj/git; only needs Jujutsu + GitHub MCPs"
        "mode" = "subagent"
        # Same model as the plan agent — strong reasoning, lower cost than build.
        "model" = "{{opencode_plan_agent_model}}"
        "prompt" = _agent_prompt("reviewer")
        # Read-only (never edits files; keeps bash/read/grep for diffs) and scoped
        # to the Jujutsu + GitHub MCP servers; all other MCP tools denied.
        "permission" = {"edit" = "deny"} | _mcp_only(["Jujutsu", "GitHub"])
    }
    # opencode's built-in search subagent. Declaring only `permission` scopes it
    # without replacing its built-in prompt or description (verified: the
    # captured system prompt still opens "You are a file search specialist").
    # It ships a fixed roster — bash/glob/grep/read plus webfetch and the MCP
    # resource tools — and carries no skills section, so unlike local-dev there
    # is no catalog to trim. `bash` stays: `rg` and `fd` are how a search agent
    # earns its keep. `webfetch` stays too: exploration legitimately runs into
    # docs and URLs, and ~320 tokens is a cheap price for that.
    #
    # The _mcp_resource_tools deny has no measurable effect here — it does not
    # strip for subagents (see the caveat above). It is kept as the standing
    # declaration of intent: if that behaviour is fixed, or if a new MCP server
    # starts leaking tools into this agent, the wildcards apply without anyone
    # having to rediscover the problem. The Backlog allows DO take effect (same
    # deny-then-allow findLast ordering local-dev relies on).
    #
    # `model` is pinned for the same reason every other local agent pins it:
    # without it explore inherits the *session* model, so running the
    # orchestrator on the 27B dragged explore onto it too. That does not fit —
    # the 27B's fitted window is 11,776 tokens, explore's fixed overhead is
    # ~6,450, and compaction.reserved takes another 2,048, leaving ~3,300 for
    # actual work. A single `read` of a 400-line file exceeds it, so the agent
    # compacts, lands back at the threshold, and compacts again — observed
    # looping at ~2 min per cycle. On the 9B's 32k the same overhead leaves
    # ~24k of working room.
    "explore" = {
        "model" = "{{opencode_local_agent_model}}"
        "permission" = _deny_all_mcp | {
            _sanitize_mcp("Backlog") + "_" + _sanitize_mcp(t): "allow"
            for t in _explore_backlog_read_tools
        } | {t: "deny" for t in _mcp_resource_tools}
    }
    # Backlog *writes* only — reads live on `explore`. Splitting them is not
    # symmetry for its own sake: it keeps `task_edit` (the single most expensive
    # schema in the local lane) out of the agent that gets invoked on every
    # discovery question, and it makes task mutation an explicit, separately
    # spawned step rather than something a small model can do as a side effect
    # of answering "what should I work on?".
    "local-pm" = {
        "description" = "Creates and updates Backlog tasks. Invoke only when the user explicitly asks to write, update, or close a task."
        "mode" = "subagent"
        "model" = "{{opencode_local_agent_model}}"
        "prompt" = _agent_prompt("local-pm")
        # Deny every server, then re-allow the named Backlog tools — same
        # deny-then-allow findLast ordering local-dev relies on. No file edits,
        # no bash (its prompt forbids VCS commands and Backlog commits its own
        # task files), no skills — none apply to writing a task.
        "permission" = _deny_all_mcp | {
            _sanitize_mcp("Backlog") + "_" + _sanitize_mcp(t): "allow"
            for t in _local_pm_backlog_write_tools
        } | {"edit" = "deny", "bash" = "deny", "skill" = "deny"}
    }
    "local-dev" = {
        "description" = "Local Development subagent that writes code and commits work (VCS via jj/git CLI)"
        "mode" = "subagent"
        "model" = "{{opencode_local_agent_model}}"
        "prompt" = _agent_prompt("local-dev")
        # Deny every MCP server, then re-allow a curated read-only slice of the
        # Jujutsu MCP. Order is load-bearing: opencode resolves a tool's schema
        # with findLast over config order (permission/index.ts `fromConfig`
        # preserves object insertion order; a schema is stripped only when the
        # tool's LAST matching rule is a string-form `*` deny). The allow keys
        # merge AFTER _deny_all_mcp, so each named jj tool's last match is its
        # allow (schema kept) while every other Jujutsu tool's last match stays
        # `Jujutsu*: deny` (stripped) — ~4 schemas instead of the ~60 the full
        # server adds. Mutations (commit/edit/restore/new) stay on `jj` via
        # bash; see the _local_dev_jj_read_tools note above.
        # The skills catalog, not the tool schemas, dominated this agent's
        # context: 52 skills / ~7,500 tokens of a ~16,000-token request. Scoping
        # it to _local_dev_skills and dropping the dead MCP-resource tools
        # roughly halves the footprint.
        #
        # webfetch was ALSO denied here ("it implements from a brief; it does
        # not browse") and that was a mistake — reverted 2026-07-22 after the
        # agent was observed reaching for `curl` instead. Denying a tool while
        # leaving `bash` does not remove the capability; it just moves it to an
        # unstructured path with no timeout, no size cap, and no format
        # handling. This is the same lesson that got `bash` denied on the
        # router, applied in the other direction: deny the *shell* to remove a
        # capability, or provide the structured tool — denying only the
        # structured tool gets you the shell version of it. ~320 tokens, and
        # local-dev cannot delegate (it has no `task` tool), so it has no other
        # legitimate way to resolve a URL the brief hands it.
        "permission" = _deny_all_mcp | {
            _sanitize_mcp("Jujutsu") + "_" + _sanitize_mcp(t): "allow"
            for t in _local_dev_jj_read_tools
        } | {t: "deny" for t in _mcp_resource_tools} | {
            "skill" = {"*" = "deny"} | {s: "allow" for s in _local_dev_skills}
        }
    }
}

opencode = {
    "$schema" = "https://opencode.ai/config.json"
    "plugin" = []
    "small_model" = "lmstudio/qwen3.5-9b"
    "compaction" = {
        "auto" = True
        "prune" = True
        "reserved" = 2048
    }
    "permission" = {
        "external_directory" = {
            "/tmp/**" = "allow"
            "/private/tmp/**" = "allow"
        }
    }
    "mcp" = {}  # Replaced by `build()` with the KCL-generated mcp dict
    "lsp" = _lsp
    "provider" = _provider
    "agent" = _agent
}

# JSONC output helper — writes a dict as JSON with a header comment
_jsonc_header = """/**
 * # PREREQUISITES:
 * - OpenCode CLI: https://opencode.ai/docs/cli/installation
 * - `npm install`
 * - Review this file and follow any inline directions in the comments.
 *
 * # INSTRUCTIONS:
 * 1. Copy this file to `~/.config/opencode/`. Remove any other `opencode.json` or `opencode.jsonc` files in that directory.
 * 2. Authenticate with Github Copilot: https://opencode.ai/docs/cli/authentication
 * 3. Run OpenCode and select the model you want to use from Github Copilot: `opencode` `/models`
 * 4. Go forth and prompt!
 */
"""

# Build the JSONC output for the given effective MCP inclusion list.
# The mcp dict is generated at KCL time so excluded servers are literally
# omitted and the rendered JSON is always valid (no Handlebars leading-comma
# tricks). URLs/tokens remain Handlebars placeholders resolved by dotter, and
# post-deploy secret injection adds bearer tokens to the live file.
build = lambda included {
    _opencode_with_mcp = {k: v for k, v in opencode if k != "mcp"} | {"mcp": mcp_shared.opencode_mcp_for(included)}
    _jsonc_header + json.encode(_opencode_with_mcp, indent=2)
}
