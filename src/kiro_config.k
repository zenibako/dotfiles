import json
import file
import _shared.mcp as mcp_shared

# ── Kiro MCP config ───────────────────────────────────────────────────
# Generated by KCL using shared MCP server definitions.
# Kiro stdio servers reuse the claude format (command/args/env).
# Kiro remote servers use {"type": "http", "url": ...}.

# Servers using claude stdio format
_stdio_servers = {
    name: cfg for name, cfg in mcp_shared.mcp_claude
    if name in ["Jujutsu", "Backlog", "Playwright", "Chrome DevTools"]
}

# Remote servers (Kiro native HTTP)
_remote_servers = {
    "GitHub": {"type" = "http", "url" = "https://api.githubcopilot.com/mcp/"}
    "Atlassian": {"type" = "http", "url" = "https://mcp.atlassian.com/v1/mcp"}
    # Disabled until the GitLab instance serves the MCP endpoint (needs Duo +
    # beta/experimental features); otherwise it 404s. Kiro's config is plain
    # KCL-built JSON with no Handlebars conditionals, so it can't read the
    # mcp_gitlab_enabled flag — re-enable here by removing "disabled".
    "GitLab": {"type" = "http", "url" = "{{gitlab_url}}/api/v4/mcp", "disabled" = True}
}

# SF PG5 servers (direct HTTP proxy — no OAuth discovery, instant connect)
_SF_PATH = "{{shell_bin_path}}:/usr/bin:/bin:/usr/sbin:/sbin"
_SF_PROXY = "/Users/{{username}}/.local/bin/sf-mcp-proxy.mjs"
_SF_PG5_ARGS = ["--token-file", "/Users/{{username}}/.sf-mcp/pg5.json", "--org-url", "https://odaseva--pg5.sandbox.my.salesforce.com", "--client-id", "{{sf_pg5_oauth_client_id}}", "--refresh-token", "{{sf_pg5_refresh_token}}"]
_sf_servers = {
    "SF PG5 Reads": {
        "command" = "{{shell_bin_path}}/node"
        "args" = [_SF_PROXY, "https://api.salesforce.com/platform/mcp/v1/sandbox/platform/sobject-reads"] + _SF_PG5_ARGS
        "env" = {"PATH" = _SF_PATH, "HOME" = "/Users/{{username}}", "NODE_EXTRA_CA_CERTS" = "{{node_extra_ca_certs}}"}
    }
    "SF PG5 Mutations": {
        "command" = "{{shell_bin_path}}/node"
        "args" = [_SF_PROXY, "https://api.salesforce.com/platform/mcp/v1/sandbox/platform/sobject-mutations"] + _SF_PG5_ARGS
        "env" = {"PATH" = _SF_PATH, "HOME" = "/Users/{{username}}", "NODE_EXTRA_CA_CERTS" = "{{node_extra_ca_certs}}"}
    }
    "SF PG5 Metadata": {
        "command" = "{{shell_bin_path}}/node"
        "args" = [_SF_PROXY, "https://api.salesforce.com/platform/mcp/v1/sandbox/platform/metadata-experts"] + _SF_PG5_ARGS
        "env" = {"PATH" = _SF_PATH, "HOME" = "/Users/{{username}}", "NODE_EXTRA_CA_CERTS" = "{{node_extra_ca_certs}}"}
    }
}

_all_servers = _stdio_servers | _remote_servers | _sf_servers

kiro_config = {"mcpServers": _all_servers}

file.write("out/kiro/mcp.json", json.encode(kiro_config, indent=2))
