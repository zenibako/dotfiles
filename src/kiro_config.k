import json
import file
import _shared.mcp as mcp_shared

# ── Kiro MCP config ───────────────────────────────────────────────────
# Generated by KCL using shared MCP server definitions (claude format).

_kiro_servers = {
    name: cfg for name, cfg in mcp_shared.mcp_claude
    if name in ["Jujutsu", "GitHub", "Backlog", "Playwright", "Chrome DevTools", "Atlassian", "GitLab"]
}

kiro_config = {"mcpServers": _kiro_servers}

file.write("out/kiro/mcp.json", json.encode(kiro_config, indent=2))
