import json
import file
import _shared.mcp as mcp_shared

# ── Claude Desktop config ─────────────────────────────────────────────
# Generated by KCL using shared MCP server definitions.
# Only includes servers that have a Claude Desktop representation.

claude_config = {
    "mcpServers" = mcp_shared.mcp_claude
    "coworkUserFilesPath" = "/Users/{{username}}/Claude"
    "preferences" = {
        "chillingSlothLocation" = {
            "customPath" = "/Users/{{username}}/Projects/workspaces"
        }
        "coworkScheduledTasksEnabled" = "{{claude_cowork_scheduled_tasks_enabled}}"
        "ccdScheduledTasksEnabled" = True
        "sidebarMode" = "epitaxy"
        "coworkWebSearchEnabled" = True
        "epitaxyPrefs" = {
            "starred-local-code-sessions" = []
            "starred-cowork-spaces" = []
            "starred-session-groups" = []
            "dframe-local-slice" = {
                "pinnedOrder" = []
                "customGroupAssignments" = {}
                "customGroupOrder" = {}
            }
            # Conditional preferences (placeholder for Handlebars)
            "cc-landing-worktree-enabled" = False
            "epitaxy-perm-mode-acks.{{claude_bypass_permissions_account_id}}" = [
                "/Users/{{username}}/projects/home-assistant:auto",
                "/Users/{{username}}/projects/cuejitsu:auto"
            ]
            "epitaxy-folder-permission-mode.{{claude_bypass_permissions_account_id}}" = {
                "/Users/{{username}}/projects/home-assistant" = "auto"
                "/Users/{{username}}/projects/cuejitsu" = "auto"
            }
        }
        "remoteToolsDeviceName" = "{{claude_remote_tools_device_name}}"
        "bypassPermissionsGateByAccount" = {
            "{{claude_bypass_permissions_account_id}}" = "{{claude_bypass_permissions_value}}"
        }
        "coworkModelAutoFallbackByAccount" = {
            "{{claude_bypass_permissions_account_id}}" = True
        }
        "ccRemoteControlDefaultEnabled" = "{{claude_agent_push_notif_enabled}}"
        "bypassPermissionsOptInByAccount" = {
            "{{claude_bypass_permissions_account_id}}" = True
        }
    }
}

# Emit the Claude Desktop config file.
#
# These preferences must render as JSON booleans, but their values come from
# Handlebars variables that dotter substitutes at deploy time. json.encode wraps
# every string value in quotes, so the rendered token is "{{var}}" and dotter
# replaces only the inner {{var}}, leaving "true"/"false" — a string the app
# rejects ("expected boolean, received string"). Strip the surrounding quotes
# here so dotter emits a bare boolean.
_rendered = json.encode(claude_config, indent=2).replace(
    "\"{{claude_cowork_scheduled_tasks_enabled}}\"", "{{claude_cowork_scheduled_tasks_enabled}}"
).replace(
    "\"{{claude_bypass_permissions_value}}\"", "{{claude_bypass_permissions_value}}"
).replace(
    "\"{{claude_agent_push_notif_enabled}}\"", "{{claude_agent_push_notif_enabled}}"
)

# ── Obsidian MCP server (Personal profile only) ────────────────────────
# Claude Desktop's mcpServers has no per-server "enabled" flag, so a disabled
# server must be omitted entirely. KCL can't emit a Handlebars {{#if}} through
# json.encode, so Obsidian is excluded from the shared mcp_claude dict
# (claude = None in _shared/mcp.k) and spliced in here as the last mcpServers
# entry. The leading comma lives inside the {{#if}} so that when the guard is
# false the preceding entry (Chrome DevTools) stays the valid last member.
_obsidian_entry = "{{#if (eq mcp_obsidian_included true)}},\n    \"Obsidian\": {\n      \"command\": \"{{shell_bin_path}}/npx\",\n      \"args\": [\n        \"-y\",\n        \"mcp-remote\",\n        \"{{mcp_obsidian_url}}\",\n        \"--allow-http\",\n        \"--header\",\n        \"Authorization:\${MCP_OBSIDIAN_AUTH}\"\n      ],\n      \"env\": {\n        \"MCP_OBSIDIAN_AUTH\": \"Bearer {{mcp_obsidian_token}}\",\n        \"PATH\": \"{{shell_bin_path}}:/usr/bin:/bin:/usr/sbin:/sbin\"\n      }\n    }{{/if}}"

# Anchor on the mcpServers close + the next top-level key (unique in the output).
_rendered = _rendered.replace(
    "\n  },\n  \"coworkUserFilesPath\"",
    _obsidian_entry + "\n  },\n  \"coworkUserFilesPath\"",
)

file.write("out/claude_desktop_config.json", _rendered)
