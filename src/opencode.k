import json
import file
import _shared.mcp as mcp_shared

# ── OpenCode (opencode.jsonc) ────────────────────────────────────────
# Generated by KCL using shared MCP server definitions.
# Profile-specific servers are included but disabled by default.
# Secrets (tokens) are injected by patch_opencode_secrets.py during deploy.

# LSP definitions
_lsp = {
    "basedpyright" = {
        "command" = ["basedpyright-langserver", "--stdio"]
        "extensions" = [".py"]
    }
    "gopls" = {
        "command" = ["gopls"]
        "extensions" = [".go"]
    }
    "html" = {
        "command" = ["vscode-html-language-server", "--stdio"]
        "extensions" = [".html", ".templ"]
    }
    "jsonls" = {
        "command" = ["vscode-json-language-server", "--stdio"]
        "extensions" = [".json", ".jsonc"]
    }
    "lua_ls" = {
        "command" = ["lua-language-server"]
        "extensions" = [".lua"]
    }
    "yamlls" = {
        "command" = ["yaml-language-server", "--stdio"]
        "extensions" = [".yml", ".yaml"]
    }
    "cue" = {
        "command" = ["cue", "lsp"]
        "extensions" = [".cue"]
    }
    "typescript-language-server" = {
        "command" = ["typescript-language-server", "--stdio"]
        "extensions" = [".ts", ".tsx", ".js", ".jsx"]
    }
    # Work profile LSPs (disabled by default)
    "apex-language-server" = {
        "command" = [
            "java",
            "-Ddebug.internal.errors=true",
            "-Ddebug.semantic.errors=false",
            "-Ddebug.completion.statistics=false",
            "-Dlwc.typegeneration.disabled=true",
            "apex.jorje.lsp.ApexLanguageServerLauncher"
        ]
        "extensions" = [".apex", ".cls", ".trigger"]
        "disabled" = True
        "initialization" = {
            "enableSemanticErrors" = True
            "enableCompletionStatistics" = False
        }
    }
    "lwc-language-server" = {
        "command" = ["~/.config/opencode/script/lwc-lsp-wrapper.sh"]
        "extensions" = [".js", ".html"]
        "disabled" = True
    }
    "visualforce-language-server" = {
        "command" = ["$HOME/.local/share/nvim/mason/bin/visualforce-language-server", "--stdio"]
        "extensions" = [".page", ".component"]
        "disabled" = True
    }
    "gitlab-ci-ls" = {
        "command" = ["gitlab-ci-ls"]
        "extensions" = [".gitlab-ci.yml", ".gitlab-ci.yaml"]
        "disabled" = True
    }
    "terraform-ls" = {
        "command" = ["terraform-ls", "serve"]
        "extensions" = [".tf", ".tfvars", ".hcl"]
        "disabled" = True
    }
    # Personal profile LSPs (disabled by default)
    "jinja-lsp" = {
        "command" = ["jinja-lsp"]
        "extensions" = [".jinja", ".jinja2"]
        "disabled" = True
    }
    "sourcekit-lsp" = {
        "command" = ["sourcekit-lsp"]
        "extensions" = [".swift"]
        "disabled" = True
    }
}

# Provider config
_provider = {
    "ollama" = {
        "npm" = "@ai-sdk/openai-compatible"
        "name" = "Ollama (local)"
        "options" = {
            "baseURL" = "http://localhost:11434/v1"
        }
        "models" = {
            "gemma4:12b-mlx" = {
                "contextWindow" = 32768
            }
            "gemma4:12b-it-qat" = {
                "contextWindow" = 16384
                "maxTokens" = 8192
            }
        }
    }
}

# Agent config
_agent = {
    "build" = {"model" = "{{opencode_build_agent_model}}"}
    "plan" = {"model" = "{{opencode_plan_agent_model}}"}
    "test" = {
        "description" = "Writes and runs tests, checks coverage, and fixes failing tests"
        "mode" = "subagent"
        "model" = "{{opencode_test_agent_model}}"
    }
    "code-review" = {
        "description" = "Reviews code using available review tools plus direct analysis"
        "mode" = "subagent"
        "model" = "{{opencode_review_agent_model}}"
        "prompt" = "You are a code reviewer..."
    }
}

opencode = {
    "$schema" = "https://opencode.ai/config.json"
    "plugin" = ["opencode-cmux"]
    "permission" = {
        "external_directory" = {
            "/tmp/**" = "allow"
            "/private/tmp/**" = "allow"
        }
    }
    "mcp" = mcp_shared.mcp_opencode
    "lsp" = _lsp
    "provider" = _provider
    "agent" = _agent
}

# JSONC output helper — writes a dict as JSON with a header comment
_jsonc_header = """/**
 * # PREREQUISITES:
 * - OpenCode CLI: https://opencode.ai/docs/cli/installation
 * - `npm install`
 * - Review this file and follow any inline directions in the comments.
 *
 * # INSTRUCTIONS:
 * 1. Copy this file to `~/.config/opencode/`. Remove any other `opencode.json` or `opencode.jsonc` files in that directory.
 * 2. Authenticate with Github Copilot: https://opencode.ai/docs/cli/authentication
 * 3. Run OpenCode and select the model you want to use from Github Copilot: `opencode` `/models`
 * 4. Go forth and prompt!
 */
"""

# Emit the JSONC file
file.write("out/opencode.jsonc", _jsonc_header + json.encode(opencode, indent=2))
