import file

# ── Codex CLI config (config.toml) ─────────────────────────────────────
# Generated by KCL. Deployed as a dotter template to ~/.codex/config.toml.
# Uses Handlebars markers resolved by dotter during deploy.

_config_toml = """# Generated by KCL — do not edit manually
# OpenAI Codex CLI config — https://openai-codex.mintlify.app/configuration

model = "gpt-5.5"
approval_policy = "on-request"
sandbox_mode = "workspace-write"
commit_attribution = "Codex <codex@ai>"

[tui]
notifications = true

[mcp_servers.jujutsu]
command = "{{shell_bin_path}}/npx"
args = ["-y", "jj-mcp-server"]
enabled = true

[mcp_servers.jujutsu.env]
PATH = "{{shell_bin_path}}:/usr/bin:/bin:/usr/sbin:/sbin"

[mcp_servers.backlog]
command = "{{shell_bin_path}}/backlog"
args = ["mcp", "start"]
enabled = true

[mcp_servers.playwright]
command = "{{shell_bin_path}}/npx"
args = ["-y", "@playwright/mcp@latest"]
enabled = true

[mcp_servers.playwright.env]
PATH = "{{shell_bin_path}}:/usr/bin:/bin:/usr/sbin:/sbin"

# GitHub Copilot MCP — bearer auth. $CODEX_GITHUB_TOKEN is exported by ~/.zshenv
# from `gh auth token` (see zshenv.k).
[mcp_servers.github]
url = "https://api.githubcopilot.com/mcp/"
bearer_token_env_var = "CODEX_GITHUB_TOKEN"
enabled = true
{{#if gitlab_url}}
# Self-hosted GitLab MCP — OAuth only (protected resource, scope "mcp"); it does
# NOT accept a personal access token. Authenticate once with:
#   codex mcp login gitlab
# The server supports dynamic client registration, so no client ID is needed.
[mcp_servers.gitlab]
url = "{{gitlab_url}}/api/v4/mcp"
enabled = true
{{/if}}
"""

file.write("out/codex/config.toml", _config_toml)
