import json
import file

# ── Claude Code settings.json ──────────────────────────────────────────
# Generated by KCL. All profile-dependent fields use Handlebars markers
# (resolved by dotter during deploy), so the source file is valid JSONC
# but the deployed file is plain JSON after dotter renders it.

# Emit settings.json as JSON with Handlebars conditionals. We build the JSON
# string manually to include Handlebars markers. MCP servers are NOT emitted
# here — Claude Code ignores `mcpServers` in settings.json. They live in a
# separate file (out/claude-code/mcp.json) merged into ~/.claude.json.
_json_parts = [
    """{
{{#if (eq claude_model_at_top true)}}
  "model": "{{claude_model}}",
{{/if}}"""
    # gitlab@claude-plugins-official is explicitly disabled (not just omitted):
    # the post-deploy merge into ~/.claude/settings.json is additive, so a value
    # only present in the live file survives forever. Its MCP server hardcodes
    # https://gitlab.com — we use the self-hosted `GitLab` http server from
    # _shared/mcp.k ({{gitlab_url}}) instead, so this plugin must stay off.
    """  "enabledPlugins": {
    "chrome-devtools-mcp@claude-plugins-official": true,
    "coderabbit@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "gitlab@claude-plugins-official": false,
    "gopls-lsp@claude-plugins-official": true,
{{#if (eq claude_plugin_extra_lsps true)}}
    "html-lsp@claude-plugins-official": true,
    "json-lsp@claude-plugins-official": true,
{{/if}}
    "lattice@lattice": true,
    "lua-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true{{#if (eq claude_plugin_extra_lsps true)}},
    "yaml-lsp@claude-plugins-official": true{{/if}}{{#if (eq claude_plugin_clangd_lsp true)}},
    "clangd-lsp@claude-plugins-official": true{{/if}}{{#if (eq claude_plugin_pyright_lsp true)}},
    "pyright-lsp@claude-plugins-official": true{{/if}}
  },"""
    """  "extraKnownMarketplaces": {
    "lattice": {
      "source": {
        "source": "github",
        "repo": "techygarg/lattice"
      }
    }
  },"""
    """{{#if (eq claude_effort_level_enabled true)}}
  "effortLevel": "{{claude_effort_level}}",
{{/if}}"""
    """  "autoUpdatesChannel": "stable",
  "editorMode": "vim",
  "permissions": {
    "defaultMode": "auto"
  },
{{#if (eq claude_agent_push_notif_enabled true)}}
  "agentPushNotifEnabled": true,
{{/if}}"""
    """{{#if (eq bartender_hooks_enabled true)}}
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "'/Users/{{username}}/Library/Application Support/Bartender/NotchBar/AgentStatus/hooks/claude-event-hook.sh' Waiting # notchbar-agents-claude-hook",
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "'/Users/{{username}}/Library/Application Support/Bartender/NotchBar/AgentStatus/hooks/claude-event-hook.sh' Auto # notchbar-agents-claude-hook",
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "command": "'/Users/{{username}}/Library/Application Support/Bartender/NotchBar/AgentStatus/hooks/claude-event-hook.sh' ToolFail # notchbar-agents-claude-hook",
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "'/Users/{{username}}/Library/Application Support/Bartender/NotchBar/AgentStatus/hooks/claude-event-hook.sh' Working # notchbar-agents-claude-hook",
            "type": "command"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "__claudebar_hook() { PORT=\\"$HOME/.claude/claudebar-hook-port\\"; cat | curl -s -X POST \\\"http://localhost:\${PORT}/hook\\" -H 'Content-Type: application/json' -d @- > /dev/null 2>&1 & }; __claudebar_hook",
            "type": "command"
          }
        ],
        "matcher": ".*"
      },
      {
        "hooks": [
          {
            "command": "'/Users/{{username}}/Library/Application Support/Bartender/NotchBar/AgentStatus/hooks/claude-event-hook.sh' Ended # notchbar-agents-claude-hook",
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "__claudebar_hook() { PORT=\\"$HOME/.claude/claudebar-hook-port\\"; cat | curl -s -X POST \\\"http://localhost:\${PORT}/hook\\" -H 'Content-Type: application/json' -d @- > /dev/null 2>&1 & }; __claudebar_hook",
            "type": "command"
          }
        ],
        "matcher": ".*"
      },
      {
        "hooks": [
          {
            "command": "'/Users/{{username}}/Library/Application Support/Bartender/NotchBar/AgentStatus/hooks/claude-event-hook.sh' Idle # notchbar-agents-claude-hook",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "__claudebar_hook() { PORT=\\"$HOME/.claude/claudebar-hook-port\\"; cat | curl -s -X POST \\\"http://localhost:\${PORT}/hook\\" -H 'Content-Type: application/json' -d @- > /dev/null 2>&1 & }; __claudebar_hook",
            "type": "command"
          }
        ],
        "matcher": ".*"
      },
      {
        "hooks": [
          {
            "command": "'/Users/{{username}}/Library/Application Support/Bartender/NotchBar/AgentStatus/hooks/claude-event-hook.sh' Idle # notchbar-agents-claude-hook",
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "command": "__claudebar_hook() { PORT=\\"$HOME/.claude/claudebar-hook-port\\"; cat | curl -s -X POST \\\"http://localhost:\${PORT}/hook\\" -H 'Content-Type: application/json' -d @- > /dev/null 2>&1 & }; __claudebar_hook",
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "command": "__claudebar_hook() { PORT=\\"$HOME/.claude/claudebar-hook-port\\"; cat | curl -s -X POST \\\"http://localhost:\${PORT}/hook\\" -H 'Content-Type: application/json' -d @- > /dev/null 2>&1 & }; __claudebar_hook",
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "command": "__claudebar_hook() { PORT=\\"$HOME/.claude/claudebar-hook-port\\"; cat | curl -s -X POST \\\"http://localhost:\${PORT}/hook\\" -H 'Content-Type: application/json' -d @- > /dev/null 2>&1 & }; __claudebar_hook",
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "'/Users/{{username}}/Library/Application Support/Bartender/NotchBar/AgentStatus/hooks/claude-event-hook.sh' Working # notchbar-agents-claude-hook",
            "type": "command"
          }
        ]
      }
    ]
  },
{{/if}}"""
    """  "skipAutoPermissionPrompt": true{{#if (eq claude_model_at_top false)}},
  "model": "{{claude_model}}"{{/if}}
}"""
]

# Join all parts — no outer wrapping, each part is self-contained
_settings_json = "\n".join(_json_parts)

file.write("out/claude-code/settings.json", _settings_json)

# ── Claude Code MCP servers (out/claude-code/mcp.json) ──────────────────
# Claude Code ignores `mcpServers` in settings.json; user-global MCP servers
# must live in ~/.claude.json top-level `mcpServers`. post_deploy.sh merges
# this file into ~/.claude.json with `--replace mcpServers`, which is safe
# because every value here is rendered (tokens come from Handlebars vars, not
# post-deploy injection) — see merge_json_config.py.
#
# Each optional server is its own independent {{#if}} with a LEADING comma, so
# enabling one never depends on another. "Chrome DevTools" is intentionally
# omitted: it is provided by the chrome-devtools-mcp plugin (enabledPlugins),
# and an explicit entry here would create a duplicate server.
#
# GitHub: remote http server with no Dynamic Client Registration (OAuth won't
# work), so it authenticates with a static bearer header. Claude Code expands
# ${GITHUB_MCP_TOKEN} at launch — the same env var Codex uses, exported from
# `gh auth token` by zshenv.k/zshrc. Escaped as \\${...} so KCL emits it literally.
#
# SonarQube: runs the MCP as a Java process in Docker (Colima). Behind Netskope
# SSL inspection the container's JVM must trust the corporate CA, so a custom
# Java trust store is mounted read-only over the image's cacerts. Build it once
# per machine (and after image updates) — see the `sonarqube-netskope-fix` skill.
# `--pull=never` requires the image to be present locally first.
_mcp_json = """{
  "mcpServers": {
    "Backlog": {
      "args": [
        "mcp",
        "start"
      ],
      "command": "{{shell_bin_path}}/backlog"
    },
    "GitHub": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer \${GITHUB_MCP_TOKEN}"
      }
    },
    "Jujutsu": {
      "args": [
        "-y",
        "jj-mcp-server"
      ],
      "command": "{{shell_bin_path}}/npx",
      "env": {
        "PATH": "{{shell_bin_path}}:/usr/bin:/bin:/usr/sbin:/sbin"
      }
    },
    "Playwright": {
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ],
      "command": "{{shell_bin_path}}/npx",
      "env": {
        "PATH": "{{shell_bin_path}}:/usr/bin:/bin:/usr/sbin:/sbin"
      }
    }{{#if mcp_atlassian_enabled}},
    "Atlassian": {
      "type": "http",
      "url": "https://mcp.atlassian.com/v1/mcp"
    }{{/if}}{{#if (eq mcp_obsidian_enabled true)}},
    "Obsidian": {
      "args": [
        "-y",
        "mcp-remote",
        "{{mcp_obsidian_url}}",
        "--allow-http",
        "--header",
        "Authorization:\${MCP_OBSIDIAN_AUTH}"
      ],
      "command": "{{shell_bin_path}}/npx",
      "env": {
        "MCP_OBSIDIAN_AUTH": "Bearer {{mcp_obsidian_token}}",
        "PATH": "{{shell_bin_path}}:/usr/bin:/bin:/usr/sbin:/sbin"
      }
    }{{/if}}{{#if mcp_sonarqube_enabled}},
    "SonarQube": {
      "args": [
        "run",
        "--init",
        "--pull=never",
        "-i",
        "--rm",
        "-v",
        "/Users/{{username}}/.docker/sonarqube/cacerts:/opt/jdk/jdk-21/lib/security/cacerts:ro",
        "-e",
        "SONARQUBE_URL",
        "-e",
        "SONARQUBE_TOKEN",
        "mcp/sonarqube:latest"
      ],
      "command": "{{shell_bin_path}}/docker",
      "env": {
        "DOCKER_CONTEXT": "colima",
        "PATH": "{{shell_bin_path}}:/usr/bin:/bin:/usr/sbin:/sbin",
        "SONARQUBE_URL": "{{sonarqube_url}}",
        "SONARQUBE_TOKEN": "{{sonarqube_token}}"
      }
    }{{/if}}{{#if mcp_gitlab_enabled}},
    "GitLab": {
      "type": "http",
      "url": "{{gitlab_url}}/api/v4/mcp"
    }{{/if}}
  }
}"""

file.write("out/claude-code/mcp.json", _mcp_json)
