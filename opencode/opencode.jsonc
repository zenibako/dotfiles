/**
 * # PREREQUISITES:
 * - OpenCode CLI: https://opencode.ai/docs/cli/installation
 * - `npm install`
 * - Review this file and follow any inline directions in the comments.
 *
 * # INSTRUCTIONS:
 * 1. Copy this file to `~/.config/opencode/`. Remove any other `opencode.json` or `opencode.jsonc` files in that directory.
 * 2. Authenticate with Github Copilot: https://opencode.ai/docs/cli/authentication
 * 3. Run OpenCode and select the model you want to use from Github Copilot: `opencode` `/models`
 * 4. Go forth and prompt!
 */
{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-cmux"
  ],
  "mcp": {
    "Jujutsu": {
      "type": "local",
      "command": [
        "{{shell_bin_path}}/npx",
        "-y",
        "jj-mcp-server"
      ],
      "environment": {
        "PATH": "{{shell_bin_path}}:/usr/bin:/bin:/usr/sbin:/sbin"
      },
      "enabled": true
    },
    "GitHub": {
      "type": "local",
      "command": [
        "{{shell_bin_path}}/npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{{github_personal_access_token}}",
        "PATH": "{{shell_bin_path}}:/usr/bin:/bin:/usr/sbin:/sbin"
      },
      "enabled": true
    },
    "Backlog": {
      "type": "local",
      "command": [
        "{{shell_bin_path}}/backlog",
        "mcp",
        "start"
      ],
      "enabled": true
    },
    "Playwright": {
      "type": "local",
      "command": [
        "{{shell_bin_path}}/npx",
        "-y",
        "@playwright/mcp@latest"
      ],
      "environment": {
        "PATH": "{{shell_bin_path}}:/usr/bin:/bin:/usr/sbin:/sbin"
      },
      "enabled": true
    },
{{#if opencode_profile_work}}
    "GitLab": {
      "type": "local",
      "command": [
        "{{shell_bin_path}}/npx",
        "-y",
        "@modelcontextprotocol/server-gitlab"
      ],
      "environment": {
        "GITLAB_PERSONAL_ACCESS_TOKEN": "{{gitlab_personal_access_token}}",
        "GITLAB_API_URL": "{{gitlab_api_url}}",
        "PATH": "{{shell_bin_path}}:/usr/bin:/bin:/usr/sbin:/sbin"
      },
      "enabled": true
    },
{{#if mcp_salesforce_dx}}
    "Salesforce DX": {
      "type": "local",
      "command": [
        "{{shell_bin_path}}/npx",
        "-y",
        "@salesforce/mcp",
        "--orgs",
        "DEFAULT_TARGET_ORG",
        "--toolsets",
        "all",
        "--allow-non-ga-tools"
      ],
      "environment": {
        "PATH": "{{shell_bin_path}}:/usr/bin:/bin:/usr/sbin:/sbin"
      },
      "enabled": true
    },
{{/if}}
{{#if mcp_odaseva}}
    "Odaseva": {
      "type": "local",
      "command": [
        "oda-mcp"
      ],
      "enabled": true
    },
{{/if}}
{{#if mcp_atlassian}}
    "Atlassian": {
      "type": "local",
      "command": [
        "{{shell_bin_path}}/npx",
        "-y",
        "mcp-remote",
        "https://mcp.atlassian.com/v1/sse"
      ],
      "environment": {
        "PATH": "{{shell_bin_path}}:/usr/bin:/bin:/usr/sbin:/sbin"
      },
      "enabled": true
    },
{{/if}}
{{#if mcp_postman}}
    "Postman": {
      "type": "remote",
      "url": "https://mcp.postman.com/mcp",
      "headers": {
        "Authorization": "Bearer {{postman_api_key}}"
      },
      "enabled": true
    },
{{/if}}
{{#if mcp_sonarqube}}
    "SonarQube": {
      "type": "local",
      "command": [
        "{{shell_bin_path}}/docker",
        "run",
        "--init",
        "--pull=always",
        "-i",
        "--rm",
        "-e",
        "SONARQUBE_URL",
        "-e",
        "SONARQUBE_TOKEN",
        "mcp/sonarqube"
      ],
      "environment": {
        "DOCKER_CONTEXT": "desktop-linux",
        "PATH": "{{shell_bin_path}}:/usr/bin:/bin:/usr/sbin:/sbin",
        "SONARQUBE_URL": "{{sonarqube_url}}",
        "SONARQUBE_TOKEN": "{{sonarqube_token}}"
      },
      "enabled": true
    },
{{/if}}
{{#if mcp_netlify}}
    "Netlify": {
      "type": "local",
      "command": [
        "{{shell_bin_path}}/npx",
        "-y",
        "@netlify/mcp"
      ],
      "environment": {
        "PATH": "{{shell_bin_path}}:/usr/bin:/bin:/usr/sbin:/sbin"
      },
      "enabled": true
    },
{{/if}}
    "Neovim": {
      "type": "local",
      "command": [
        "{{shell_bin_path}}/npx",
        "-y",
        "mcp-neovim-server"
      ],
      "environment": {
        "ALLOW_SHELL_COMMANDS": "true",
        "NVIM_SOCKET_PATH": "/tmp/nvim",
        "PATH": "{{shell_bin_path}}:/usr/bin:/bin:/usr/sbin:/sbin"
      },
      "enabled": false
    },
{{/if}}
{{#if n8n_mcp_token}}
    "n8n": {
      "type": "remote",
      "url": "{{n8n_mcp_url}}",
      "headers": {
        "Authorization": "Bearer {{n8n_mcp_token}}"
      },
      "enabled": true
    },
{{/if}}
{{#if gitea_token}}
    "Gitea": {
      "type": "local",
      "command": [
        "/Users/{{username}}/go/bin/forgejo-mcp",
        "stdio",
        "--server", "{{gitea_url}}",
        "--token", "{{gitea_token}}"
      ],
      "environment": {
        "PATH": "{{shell_bin_path}}:/usr/bin:/bin:/usr/sbin:/sbin"
      },
      "enabled": true
    },
{{/if}}
    "Chrome DevTools": {
      "type": "local",
      "command": [
        "{{shell_bin_path}}/npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--launch"
      ],
      "environment": {
        "PATH": "{{shell_bin_path}}:/usr/bin:/bin:/usr/sbin:/sbin"
      },
      "enabled": true
    },
  },
  "lsp": {
{{#if opencode_profile_work}}
    "apex-language-server": {
      "command": [
        "java",
        "-cp",
        "{{apex_lsp_jar_path}}",
        "-Ddebug.internal.errors=true",
        "-Ddebug.semantic.errors=true",
        "-Ddebug.completion.statistics=false",
        "-Dlwc.typegeneration.disabled=true",
        "apex.jorje.lsp.ApexLanguageServerLauncher"
      ],
      "extensions": [
        ".apex",
        ".cls",
        ".trigger"
      ],
      "disabled": false,
      "initialization": {
        "enableSemanticErrors": true,
        "enableCompletionStatistics": false
      }
    },
    "lwc-language-server": {
      "command": [
        "~/.config/opencode/script/lwc-lsp-wrapper.sh"
      ],
      "extensions": [
        ".js",
        ".html"
      ],
      "disabled": false
    },
    "visualforce-language-server": {
      "command": [
        "$HOME/.local/share/nvim/mason/bin/visualforce-language-server",
        "--stdio"
      ],
      "extensions": [
        ".page",
        ".component"
      ],
      "disabled": false
    },
{{/if}}
    "sourcekit-lsp": {
      "command": [
        "sourcekit-lsp"
      ],
      "extensions": [
        ".swift"
      ]
    },
    "cue": {
      "command": [
        "cue",
        "lsp"
      ],
      "extensions": [
        ".cue"
      ]
    },
    "typescript-language-server": {
      "command": [
        "typescript-language-server",
        "--stdio"
      ],
      "extensions": [
        ".ts",
        ".tsx",
        ".js",
        ".jsx"
      ]
    }
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "http://mac-mini.local:11434/v1"
      },
      "models": {
        "gemma4:latest": {
          "name": "Gemma 4"
        },
        "qwen3-coder:latest": {
          "name": "Qwen3 Coder"
        }
      }
    }
  },
  "agent": {
    "build": {
      "model": "{{#if opencode_build_agent_model}}{{opencode_build_agent_model}}{{else}}anthropic/claude-sonnet-4-6{{/if}}"
    },
    "plan": {
      "model": "{{#if opencode_plan_agent_model}}{{opencode_plan_agent_model}}{{else}}anthropic/claude-opus-4-7{{/if}}"
    },
    "test": {
      "description": "Writes and runs tests, checks coverage, and fixes failing tests",
      "mode": "subagent",
      "model": "{{#if opencode_test_agent_model}}{{opencode_test_agent_model}}{{else}}anthropic/claude-sonnet-4-6{{/if}}"
    },
    "code-review": {
      "description": "Reviews code using available review tools plus direct analysis",
      "mode": "subagent",
      "model": "{{#if opencode_review_agent_model}}{{opencode_review_agent_model}}{{else}}anthropic/claude-sonnet-4-6{{/if}}",
      "prompt": "You are a code reviewer.{{#if opencode_profile_personal}} First, run `coderabbit review --agent --type all` using bash to gather review findings.{{/if}}{{#if opencode_profile_work}} First, use the SonarQube MCP tools to inspect the relevant project, pull request, issues, and security hotspots when that context is available.{{/if}} Then analyze the code yourself for additional issues. Focus on security, performance, maintainability, correctness, and test coverage. Combine tool findings with your own review into actionable feedback."
    }
  }
}
