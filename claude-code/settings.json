{
  "enabledPlugins": {
    "chrome-devtools-mcp@claude-plugins-official": true,
    "coderabbit@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "html-lsp@claude-plugins-official": true,
    "json-lsp@claude-plugins-official": true,
    "lattice@lattice": true,
    "lua-lsp@claude-plugins-official": true,
    "python-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "yaml-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "lattice": {
      "source": {
        "source": "github",
        "repo": "techygarg/lattice"
      }
    }
  },
  "autoUpdatesChannel": "stable",
  "editorMode": "vim",
{{#if (eq claude_effort_level_enabled true)}}
  "effortLevel": "{{claude_effort_level}}",
{{/if}}
{{#if (eq claude_agent_push_notif_enabled true)}}
  "agentPushNotifEnabled": true,
{{/if}}
  "skipAutoPermissionPrompt": true,
{{#if (eq bartender_hooks_enabled true)}}
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "'/Users/{{username}}/Library/Application Support/Bartender/NotchBar/AgentStatus/hooks/claude-event-hook.sh' Waiting # notchbar-agents-claude-hook",
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "'/Users/{{username}}/Library/Application Support/Bartender/NotchBar/AgentStatus/hooks/claude-event-hook.sh' Auto # notchbar-agents-claude-hook",
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "command": "'/Users/{{username}}/Library/Application Support/Bartender/NotchBar/AgentStatus/hooks/claude-event-hook.sh' ToolFail # notchbar-agents-claude-hook",
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "'/Users/{{username}}/Library/Application Support/Bartender/NotchBar/AgentStatus/hooks/claude-event-hook.sh' Working # notchbar-agents-claude-hook",
            "type": "command"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "__claudebar_hook() { PORT=\"$HOME/.claude/claudebar-hook-port\"; cat | curl -s -X POST \"http://localhost:${PORT}/hook\" -H 'Content-Type: application/json' -d @- > /dev/null 2>&1 & }; __claudebar_hook",
            "type": "command"
          }
        ],
        "matcher": ".*"
      },
      {
        "hooks": [
          {
            "command": "'/Users/{{username}}/Library/Application Support/Bartender/NotchBar/AgentStatus/hooks/claude-event-hook.sh' Ended # notchbar-agents-claude-hook",
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "__claudebar_hook() { PORT=\"$HOME/.claude/claudebar-hook-port\"; cat | curl -s -X POST \"http://localhost:${PORT}/hook\" -H 'Content-Type: application/json' -d @- > /dev/null 2>&1 & }; __claudebar_hook",
            "type": "command"
          }
        ],
        "matcher": ".*"
      },
      {
        "hooks": [
          {
            "command": "'/Users/{{username}}/Library/Application Support/Bartender/NotchBar/AgentStatus/hooks/claude-event-hook.sh' Idle # notchbar-agents-claude-hook",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "__claudebar_hook() { PORT=\"$HOME/.claude/claudebar-hook-port\"; cat | curl -s -X POST \"http://localhost:${PORT}/hook\" -H 'Content-Type: application/json' -d @- > /dev/null 2>&1 & }; __claudebar_hook",
            "type": "command"
          }
        ],
        "matcher": ".*"
      },
      {
        "hooks": [
          {
            "command": "'/Users/{{username}}/Library/Application Support/Bartender/NotchBar/AgentStatus/hooks/claude-event-hook.sh' Idle # notchbar-agents-claude-hook",
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "command": "__claudebar_hook() { PORT=\"$HOME/.claude/claudebar-hook-port\"; cat | curl -s -X POST \"http://localhost:${PORT}/hook\" -H 'Content-Type: application/json' -d @- > /dev/null 2>&1 & }; __claudebar_hook",
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "command": "__claudebar_hook() { PORT=\"$HOME/.claude/claudebar-hook-port\"; cat | curl -s -X POST \"http://localhost:${PORT}/hook\" -H 'Content-Type: application/json' -d @- > /dev/null 2>&1 & }; __claudebar_hook",
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "command": "__claudebar_hook() { PORT=\"$HOME/.claude/claudebar-hook-port\"; cat | curl -s -X POST \"http://localhost:${PORT}/hook\" -H 'Content-Type: application/json' -d @- > /dev/null 2>&1 & }; __claudebar_hook",
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "'/Users/{{username}}/Library/Application Support/Bartender/NotchBar/AgentStatus/hooks/claude-event-hook.sh' Working # notchbar-agents-claude-hook",
            "type": "command"
          }
        ]
      }
    ]
  },
{{/if}}
  "mcpServers": {
    "Backlog": {
      "args": [
        "mcp",
        "start"
      ],
      "command": "{{shell_bin_path}}/backlog"
    },
    "Chrome DevTools": {
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--launch"
      ],
      "command": "{{shell_bin_path}}/npx",
      "env": {
        "PATH": "{{shell_bin_path}}:/usr/bin:/bin:/usr/sbin:/sbin"
      }
    },
    "GitHub": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "command": "{{shell_bin_path}}/npx",
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{{github_personal_access_token}}",
        "PATH": "{{shell_bin_path}}:/usr/bin:/bin:/usr/sbin:/sbin"
      }
    },
    "Jujutsu": {
      "args": [
        "-y",
        "jj-mcp-server"
      ],
      "command": "{{shell_bin_path}}/npx",
      "env": {
        "PATH": "{{shell_bin_path}}:/usr/bin:/bin:/usr/sbin:/sbin"
      }
    },
    "Playwright": {
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ],
      "command": "{{shell_bin_path}}/npx",
      "env": {
        "PATH": "{{shell_bin_path}}:/usr/bin:/bin:/usr/sbin:/sbin"
      }
    },
    "Obsidian": {
      "args": [
        "-y",
        "mcp-remote",
        "http://mac-mini.local:27123/mcp"
      ],
      "command": "{{shell_bin_path}}/npx",
      "env": {
        "PATH": "{{shell_bin_path}}:/usr/bin:/bin:/usr/sbin:/sbin"
      }
    }
  },
  "model": "{{claude_model}}"
}
