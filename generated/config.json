        "sudo",
        "pnpm",
        "npm",
        "yarn"
      ]
    },
    "sync": {
      "records": true
    },
    "daemon": {
      "enabled": true,
      "autostart": true
    },
    "dotfiles": {
      "enabled": true
    },
    "ai": {
      "enabled": true
    }
  },
  "starship": {
    "add_newline": true,
    "format": "$username$hostname$localip$shlvl$singularity$kubernetes$directory$vcsh$fossil_branch$fossil_metrics$git_branch$git_commit$git_state$git_metrics$git_status${custom.jj_change}${custom.jj_empty}${custom.jj_desc}$all",
    "right_format": "$shell",
    "command_timeout": 750,
    "package": {
      "disabled": true
    },
    "git_commit": {
      "disabled": true
    },
    "custom": {
      "sf": {
        "description": "The target org used by default for Salesforce CLI commands",
        "command": "sf config get target-org --json | from json | get result.value.0",
        "when": "sf config get target-org --json | from json | get result.value",
        "format": "via [$symbol ($output)]($style) ",
        "style": "bold 039",
        "symbol": "󰢎"
      },
      "jj_change": {
        "description": "The working copy of the repo in your current directory",
        "command": "jj log --no-graph -r=@ -T='separate(\" \", working_copies, change_id.shortest(), bookmarks,)'",
        "when": "jj root",
        "format": "on [$symbol ($output)]($style) ",
        "symbol": "🐦",
        "style": "bold purple",
        "ignore_timeout": true
      },
      "jj_empty": {
        "description": "Shows (empty) in green if the working copy has no changes",
        "command": "echo \"(empty)\"",
        "when": "jj log --no-graph -r=@ -T='if(empty, \"y\", \"\")' | grep -q '^y$'",
        "format": "[$output]($style) ",
        "style": "bold green",
        "ignore_timeout": true
      },
      "jj_desc": {
        "description": "The description of your working copy, if set",
        "command": "jj log --no-graph -r=@ -T='if(description, description.first_line(), \"(no description)\")'",
        "when": "jj root",
        "format": "$symbol [($output)]($style) ",
        "symbol": "|",
        "ignore_timeout": true
      }
    },
    "shell": {
      "disabled": false,
      "format": "[$indicator]($style) "
    }
  },
  "templates": {
    "jj": {
      "user": {
        "name": {
          "TEMPLATE_MARKER": "name"
        },
        "email": {
          "TEMPLATE_MARKER": "email"
        }
      },
      "ui": {
        "default_command": [
          "log",
          "--limit",
          "5"
        ],
        "diff_editor": ":builtin",
        "show_cryptographic_signatures": true
      },
      "signing": {
        "sign_all": true,
        "backend": "gpg",
        "key": {
          "TEMPLATE_MARKER": "gpg_key"
        }
      },
      "merge_tools": {
        "diffconflicts": {
          "program": "nvim",
          "merge_args": [
            "-c",
            "let g:jj_diffconflicts_marker_length=$marker_length",
            "-c",
            "JJDiffConflicts!",
            "$output",
            "$base",
            "$left",
            "$right"
          ],
          "merge_tool_edits_conflict_markers": true
        }
      }
    },
    "tmux": {
      "theme_plugin": {
        "TEMPLATE_MARKER": "tmux_theme_plugin"
      },
      "theme_config": {
        "TEMPLATE_MARKER": "tmux_theme_config"
      }
    },
    "ghostty": "font-family = \"MesloLGMDZ Nerd Font Mono\"\n\ntheme = \"{{ ghostty_theme }}\"\n\nbackground-opacity  = 0.85\nbackground-blur     = true\nbackground          = \"#000000\"\n\nmacos-titlebar-style = \"transparent\"\n\nmouse-hide-while-typing = true\nscrollback-limit = 1000000\ncopy-on-select = true\nwindow-save-state = always\n\nkeybind = super+r=reload_config\n\n# Split navigation with vim-style hjkl\nkeybind = super+h=goto_split:left\nkeybind = super+j=goto_split:bottom\nkeybind = super+k=goto_split:top\nkeybind = super+l=goto_split:right\n\n# Split pane visual distinction\nunfocused-split-opacity = 0.7\nunfocused-split-fill = {{ ghostty_unfocused_split_fill }}\nsplit-divider-color = {{ ghostty_split_divider_color }}\n\n# Default shell: Nushell (via sh to set XDG_CONFIG_HOME before exec)\ncommand = /bin/sh -c 'XDG_CONFIG_HOME=$HOME/.config exec {{ shell_bin_path }}/nu -l'\n\n# Allow tmux to set window title\nwindow-title-font-family = \"MesloLGMDZ Nerd Font Mono\"\n"
  },
