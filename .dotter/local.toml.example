# Dotter Local Configuration Example
# Copy this file to local.toml and fill in your actual values
# WARNING: Never commit local.toml - it contains secrets!

includes = []

# Packages system:
# - `default` package contains all common files (starship, nvim, opencode, etc.)
# - `personal` and `work` profiles use `depends = ["default"]` to automatically include default files
# - Only select ONE profile (personal OR work), which will auto-include default via depends
# - Add platform package (mac OR linux) for platform-specific files
# - Add ONE theme (monokai, nightowl, or tokyonight)
packages = ["personal", "mac", "monokai"]

[files]

[variables]
# Local variables override selected package variables. Keep all machine-specific
# values here; local.toml does not support package-specific sections such as
# [work.variables].

# REQUIRED: Name for Git/Jujutsu commits
name = "Your Name"

# REQUIRED: Email for Git/Jujutsu commits
# Use your work email for work profile, personal email for personal profile
email = "your@email.com"

# GPG signing key for Jujutsu commits
# Set to your GPG key ID (e.g., "ABCD1234EFGH5678" or "your.email@example.com")
# Leave as empty string to disable GPG signing
gpg_key = ""

# Username for system paths (override based on your actual username)
# username = "your-username"

# Profile-specific overrides:
# For 'work' profile, uncomment and set these:
# mcp_atlassian_enabled = true
# opencode_build_agent_model = "openai/gpt-5.4"
# opencode_plan_agent_model = "openai/gpt-5.4"
# gitlab_url = "https://gitlab.yourcompany.com"
# gitlab_api_url = "https://gitlab.yourcompany.com/api/v4"
# node_extra_ca_certs = "/Library/Application Support/Netskope/STAgent/download/nscacert_combined.pem"
# p10k_root_dir = "/opt/homebrew/share/powerlevel10k"

# For 'personal' profile, uncomment and set these:
# playdate_sdk_enabled = true
# bartender_hooks_enabled = true      # Only on macOS machines with Bartender installed

# Home Assistant MCP server (personal profile)
# Claude Desktop uses OAuth natively. OpenCode uses the long-lived access token below.
mcp_home_assistant_enabled = true
home_assistant_url = "http://homeassistant.local:8123"

# Other MCP servers (disabled by default, can be enabled per-machine)
# Note: work profile has mcp_odaseva and mcp_sonarqube disabled by default
# To enable work-only services, add these to local.toml:
# mcp_odaseva_enabled = true
# mcp_sonarqube_enabled = true
# sonarqube_url = "https://sonarqube.yourcompany.com"
# sonarqube_token = "squ_YOUR_TOKEN_HERE"
# mcp_postman_enabled = false  # Enabled by default in work profile
# mcp_salesforce_dx_enabled = true  # Disabled by default in work profile
# mcp_atlassian_enabled = true  # Disabled by default in work profile

# Corporate SSL certificate configuration (work profile)
# If your network uses a corporate proxy with custom SSL certificates (e.g. Netskope),
# set the host path to the CA certificate file and the container mount path.
# Leave empty if not behind a corporate proxy.
ca_cert_host_path = ""
ca_cert_container_path = "/tmp/corp-ca.pem"

# Java SSL trust store options for MCP servers running in Docker
# Used when SonarQube MCP needs to trust a corporate CA cert
# Example: "-Djavax.net.ssl.trustStore=/etc/ssl/certs/java/cacerts -Djavax.net.ssl.trustStorePassword=changeit"
java_tool_options = ""

# Secret Management
# --------------------------------
# Sensitive credentials (tokens, API keys, passwords) are NOT stored in this file.
# Instead they are fetched from Proton Pass and injected into deployed configs
# during `dotter deploy`. No secrets are ever exported as shell env vars.
#
# Requirement: Proton Pass CLI (`pass-cli`)
#   Install: brew install proton-pass-cli  (or equivalent for your platform)
#
# Setup: store each secret in your Proton Pass vault with the vault/item name shown
# in opencode/script/proton-pass-env.sh.
#
# To migrate a credential out of this file:
#   1. Store the secret in your Proton Pass vault with the correct key name
#   2. Remove or empty the variable declaration below
#   3. Run `dotter deploy -f` to pick up changes
#
# Non-sensitive values (URLs, handles, flags) can still be declared here.

# GitHub Personal Access Token (for gh CLI, Neovim plugins)
# Create at: https://github.com/settings/tokens
# DEPRECATED: Store in your secret backend (Proton Pass vault "Development", item "GitHub PAT"
#   OR macOS Keychain service "GITHUB_PERSONAL_ACCESS_TOKEN")
# github_personal_access_token = "ghp_YOUR_TOKEN_HERE"

# GitLab Personal Access Token (for gitlab.nvim plugin and MCP)
# Create at: https://gitlab.com/-/user_settings/personal_access_tokens
# DEPRECATED: Use Proton Pass — vault "Work", item "GitLab PAT"
# gitlab_personal_access_token = ""

# Home Assistant Long-Lived Access Token (used by OpenCode MCP)
# Create at: http://homeassistant.local:8123/profile/security
# DEPRECATED: Use Proton Pass — vault "Home", item "Home Assistant Token"
# home_assistant_token = "eyJhbGci..."

# Bluesky credentials (personal profile)
bluesky_handle = "your.handle.bsky.social"
# DEPRECATED: Use Proton Pass — vault "Social", item "Bluesky App Password"
# bluesky_app_password = "xxxx-xxxx-xxxx-xxxx"

# Plex credentials (personal profile)
# DEPRECATED: Use Proton Pass — vault "Media", items "Plex User Token", "Plex Server Token"
# plex_user_token = "YOUR_PLEX_USER_TOKEN"
# plex_server_token = "YOUR_PLEX_SERVER_TOKEN"
plex_url = "https://YOUR_PLEX_SERVER:32400"

# TMDB API key (for Plex watchlist)
# DEPRECATED: Use Proton Pass — vault "Media", item "TMDB API Key"
# tmdb_key = "YOUR_TMDB_API_KEY"

# Google API keys
# DEPRECATED: Use Proton Pass — vault "Development", items "YouTube API Key", "Google Places API Key"
# youtube_api_key = "YOUR_YOUTUBE_API_KEY"
# google_places_api_key = "YOUR_GOOGLE_PLACES_API_KEY"

# Slack (cookie auth)
# DEPRECATED: Use Proton Pass — vault "Work", items "Slack Token", "Slack D-Cookie"
# slack_d_cookie = "xoxd-..."
# slack_token = "xoxc-..."

# Reddit credentials (personal profile)
# DEPRECATED: Use Proton Pass — vault "Social", items "Reddit Session", "Reddit Token v2"
# reddit_session = "eyJhbGci..."
# reddit_token_v2 = "eyJhbGci..."

# Brave Search API (for OpenClaw web search)
# Create at: https://brave.com/search/api/ (choose "Data for Search" plan)
# DEPRECATED: Use Proton Pass — vault "Development", item "Brave Search API Key"
# brave_search_api_key = "BSA_YOUR_API_KEY_HERE"

# Proton Mail Bridge credentials
# DEPRECATED: Use Proton Pass — vault "Email", item "Proton Bridge Password"
# proton_user = "your@email.com"
# proton_password = "YOUR_PROTON_BRIDGE_PASSWORD"

# Telegram Bot Token
# DEPRECATED: Use Proton Pass — vault "Development", item "Telegram Bot Token"
# telegram_bot_token = "1234567890:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# Grampsweb Credentials
grampsweb_username = "your@email.com"
# DEPRECATED: Use Proton Pass — vault "Home", item "Grampsweb Password"
# grampsweb_password = "YOUR_GRAMPSWEB_PASSWORD"

# TripIt credentials
# DEPRECATED: Use Proton Pass — vault "Travel", item "TripIt Password"
# tripit_password = "Jz.i9bWQo7JLktq"

# Last.fm credentials
# DEPRECATED: Use Proton Pass — vault "Media", item "Last.fm API Key"
# last_fm_api_key = "YOUR_LAST_FM_API_KEY"
last_fm_username = "chanderson90"

# Rocksky credentials
rocksky_handle = "chanderson.tech"
# DEPRECATED: Use Proton Pass — vault "Media", item "Rocksky Password"
# rocksky_password = "YOUR_ROCKSKY_PASSWORD"

# Obsidian MCP token
# DEPRECATED: Use Proton Pass — vault "Development", item "Obsidian MCP Token"
# mcp_obsidian_token = "YOUR_OBSIDIAN_TOKEN"

# Work credentials (only needed for work profile)
# DEPRECATED: Use Proton Pass — vault "Work"
# sonarqube_token = "YOUR_SONAR_TOKEN"
# postman_api_key = "YOUR_POSTMAN_API_KEY"
